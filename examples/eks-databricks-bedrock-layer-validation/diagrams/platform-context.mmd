    SG_CAT --> SG_UI
  end

  subgraph users["Users"]
    WEB["Web / API clients"]
    ANALYSTS["Data scientists"]
    BIZ["Business users"]
  end

  subgraph eks_plane["L2 — EKS application plane"]
    INGRESS["Helm Ingress"]
